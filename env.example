# ── Docker Hub credentials (optional) ─────────────────────────────────────
# Leave blank for anonymous monitoring (100 pulls / 6 h per IP).
# Set to check an authenticated account's quota (200 pulls / 6 h for free tier).
DOCKERHUB_USERNAME=
DOCKERHUB_PASSWORD=

# ── Exporter ───────────────────────────────────────────────────────────────
# Polling interval in seconds. HEAD requests to ratelimitpreview/test are free
# and do NOT count against quour rate limit, so frequent polling is fine.
POLL_INTERVAL=60

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

IP_ALLOWLIST=